# Orders Service Environment Configuration

# Service Configuration
ORDERS_SERVICE_PORT=4003
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=ecommerce_orders

# Kafka Configuration
KAFKA_BROKERS=localhost:9092

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Configuration (for WebSocket authentication)
JWT_SECRET=jwt-secret-key-here

# Email Configuration (for order notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASS=app-password

# External Service URLs
AUTH_SERVICE_URL=http://localhost:4001
PRODUCTS_SERVICE_URL=http://localhost:4002
PAYMENTS_SERVICE_URL=http://localhost:4004
INVENTORY_SERVICE_URL=http://localhost:4005
SHIPPING_SERVICE_URL=http://localhost:4006
NOTIFICATIONS_SERVICE_URL=http://localhost:4007