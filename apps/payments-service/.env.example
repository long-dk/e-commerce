# Payments Service Environment Configuration

# Service Configuration
PAYMENTS_SERVICE_PORT=4004
NODE_ENV=development

# Database Configuration
PAYMENTS_DB_HOST=localhost
PAYMENTS_DB_PORT=5432
PAYMENTS_DB_USERNAME=postgres
PAYMENTS_DB_PASSWORD=password
PAYMENTS_DB_NAME=payments

# Kafka Configuration
KAFKA_BROKERS=localhost:9092

# Payment Gateway Configuration
# Stripe
STRIPE_SECRET_KEY=sk_test_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_webhook_secret_here

# PayPal
PAYPAL_CLIENT_ID=paypal_client_id
PAYPAL_CLIENT_SECRET=paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox

# Security
JWT_SECRET=jwt-secret-key-here
ENCRYPTION_KEY=32-character-encryption-key

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring
PROMETHEUS_PORT=9464

# External Services
ORDERS_SERVICE_URL=http://localhost:4003
AUTH_SERVICE_URL=http://localhost:4001