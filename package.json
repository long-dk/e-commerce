  "scripts": {
    "build": "nest build",
    "build:all": "yarn build && nest build auth-service && nest build products-service && nest build orders-service && nest build payments-service && nest build inventory-service && nest build shipping-service && nest build notifications-service",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/e-commerce/main",
    "start:auth": "nest start auth-service --debug --watch",
    "start:products": "nest start products-service --debug --watch",
    "test:websocket": "node apps/products-service/test-websocket.js",
    "test:orders-websocket": "node apps/orders-service/test-websocket.js",
    "demo:realtime": "node apps/products-service/demo-realtime-features.js",
    "demo:orders": "npx http-server . -p 8080 -o orders-demo.html",
    "start:payments": "nest start payments-service --debug --watch",
    "test:payments-websocket": "node apps/payments-service/test-websocket.js",
    "demo:payments": "npx http-server . -p 8080 -o payments-demo.html",
    "start:orders": "nest start orders-service --debug --watch",
    "start:inventory": "nest start inventory-service --debug --watch",
    "start:shipping": "nest start shipping-service --debug --watch",
    "start:notifications": "nest start notifications-service --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/e-commerce/test/jest-e2e.json"
  },
